# DigitalOcean Gradient Serverless Inference (replaces Anthropic + used for all Claude calls)
# Get from: DO dashboard → AI/ML → Serverless Inference → API Keys
DO_MODEL_ACCESS_KEY=...
# Check available model names in the DO Serverless Inference dashboard
DO_MODEL=anthropic-claude-haiku-4-5-20251001
# Check exact embedding model name in DO Serverless Inference dashboard
DO_EMBEDDING_MODEL=thenlper/gte-large

# Anthropic — no longer needed if using DO Gradient
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — no longer needed, embeddings now use DO Gradient
# OPENAI_API_KEY=sk-...

# Postgres with pgvector
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://localhost:5432/foialens

# Production frontend URL (set in Digital Ocean for the backend service)
FRONTEND_URL=http://localhost:3000
