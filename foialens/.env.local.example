# OpenRouter — used for all inference
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=...
# Main investigation model (needs strong tool-use reasoning)
OPENROUTER_MODEL=google/gemini-3.5-flash
NEXT_PUBLIC_OPENROUTER_MODEL=google/gemini-3.5-flash
# Extraction tools model — used for entity/timeline extraction
OPENROUTER_EXTRACT_MODEL=google/gemini-3.5-flash
# Embedding model
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Postgres with pgvector
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://localhost:5432/foialens

# Production frontend URL (set in Digital Ocean for the backend service)
FRONTEND_URL=http://localhost:3000

# DO Spaces — PDF file storage
# Get from: DO dashboard → Spaces → Manage Keys
DO_SPACES_KEY=...
DO_SPACES_SECRET=...
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
