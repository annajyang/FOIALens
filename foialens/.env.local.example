# DigitalOcean Gradient Serverless Inference (replaces Anthropic + used for all Claude calls)
# Get from: DO dashboard → AI/ML → Serverless Inference → API Keys
DO_MODEL_ACCESS_KEY=...
# Main investigation model (needs strong tool-use reasoning)
DO_MODEL=anthropic-claude-haiku-4.5
# Extraction tools model — cheaper, used for entity/timeline extraction
DO_EXTRACT_MODEL=anthropic-claude-haiku-4.5
# Embedding model
DO_EMBEDDING_MODEL=gte-large-en-v1.5

# Anthropic — no longer needed if using DO Gradient
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — no longer needed, embeddings now use DO Gradient
# OPENAI_API_KEY=sk-...

# Postgres with pgvector
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://localhost:5432/foialens

# Production frontend URL (set in Digital Ocean for the backend service)
FRONTEND_URL=http://localhost:3000

# DO Spaces — PDF file storage
# Get from: DO dashboard → Spaces → Manage Keys
DO_SPACES_KEY=...
DO_SPACES_SECRET=...
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
